# =============================================================================
# SaaS — Environment Variables Template
# Copy this file to .env.local and fill in your values.  .env.local is git-ignored.
#
# Legend:
#   [REQUIRED]  app won't run / core flows break without it
#   [PAYMENTS]  only needed for the subscription checkout + webhook (Midtrans).
#               Without these, pages still render and plans still list — only the
#               "Berlangganan" action and the webhook fail (handled gracefully).
#   [MIGRATE]   only needed to run `pnpm db:migrate`
#   [OPTIONAL]  safe to leave as-is
# =============================================================================

# --- Supabase (client) -------------------------------------------------------
# [REQUIRED] Project URL + publishable/anon key. Supabase dashboard → Project
# Settings → API. The client factories read NEXT_PUBLIC_SUPABASE_ANON_KEY; set it
# to the project's publishable key value.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here
# [OPTIONAL] kept for reference; not read by the client factories.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# --- Supabase (server / database) -------------------------------------------
# [MIGRATE] Connection strings for `pnpm db:migrate` (uses DIRECT_URL).
# Supabase dashboard → Project Settings → Database → Connection string.
DATABASE_URL="postgres://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres"

# [PAYMENTS] Service-role key — SERVER ONLY, bypasses RLS. Used by the Midtrans
# webhook and the checkout action to write payments/subscriptions. NEVER expose to
# the browser (no NEXT_PUBLIC_ prefix). Supabase dashboard → Project Settings → API
# → service_role secret. If absent, the checkout action throws "Supabase service
# env vars are not set" when a user clicks Berlangganan.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Midtrans (payment gateway) ---------------------------------------------
# [PAYMENTS] From the Midtrans dashboard → Settings → Access Keys.
# Use the Sandbox keys for development (SB-Mid-*), Production keys for live.
# - MIDTRANS_SERVER_KEY            : server-only; Snap API + status API + webhook
#                                    signature. If absent, the webhook returns 500
#                                    and checkout returns "Gagal menghubungi Midtrans".
# - NEXT_PUBLIC_MIDTRANS_CLIENT_KEY: browser; loads snap.js. If absent, the Snap
#                                    popup won't init (user sees a load error).
# - NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION: "false" = sandbox (default), "true" = live.
#   Drives BOTH the server API base URL and the client snap.js URL.
MIDTRANS_SERVER_KEY=SB-Mid-server-your_key_here
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-your_key_here
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# Midtrans webhook (Payment Notification URL), set in the Midtrans dashboard →
# Settings → Configuration:
#   https://YOUR_DOMAIN/api/midtrans/notification
# In local dev without a public tunnel, leave it unset — the return-page status
# reconcile settles payments instead.

# --- App ---------------------------------------------------------------------
# [REQUIRED] Public base URL of the web app (used for absolute links/redirects).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# [OPTIONAL] Display name.
NEXT_PUBLIC_APP_NAME="SaaS"

# --- Legacy / unused ---------------------------------------------------------
# [OPTIONAL] Maps were removed from this starter; this token is unused.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here
