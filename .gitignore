# =============================================================================
# SaaS — Turborepo Monorepo .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment Variables (NEVER commit secrets)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example

# -----------------------------------------------------------------------------
# Node / pnpm / npm
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Lock files — keep pnpm-lock.yaml, ignore others
package-lock.json
yarn.lock

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
.next/
out/
build/
dist/

# Next.js cache
.next/cache/

# Vercel
.vercel

# -----------------------------------------------------------------------------
# Turborepo
# -----------------------------------------------------------------------------
.turbo/

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
cypress/videos/
cypress/screenshots/
playwright-report/
test-results/

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
supabase/.branches/
supabase/.temp/

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
storybook-static/

# Project-specific internal docs (not for version control)

/.plan/